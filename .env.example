# Environment Variables for Meal Planner

# USDA FoodData Central API Key (REQUIRED)
# Get your free API key at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-api-key-here

# OpenAI API Key (REQUIRED for Instagram recipe import and text parsing)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Instagram Session File (OPTIONAL)
# Path to Instaloader session file for automatic Instagram fetching
# If not set, defaults to .instaloader-session
# To create: run "instaloader --login=your_username" in terminal
# INSTAGRAM_SESSION_FILE=/path/to/.instaloader-session

# Database (REQUIRED)
# PostgreSQL connection string. The app creates the default household at startup.
DATABASE_URL=postgresql+psycopg://localhost/mealplanner

# Default household ID — leave as-is for single-user deployments.
# DEFAULT_HOUSEHOLD_ID=00000000-0000-0000-0000-000000000001

# Sentry error tracking (OPTIONAL)
# Create a project at https://sentry.io and copy the DSN here.
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Application environment — used by Sentry and structured logs.
ENV=development

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
